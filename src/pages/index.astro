<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  
  <!-- Primary Meta Tags -->
  <title>Daffa Aufa | Creative Frontend Engineer & Designer</title>
  <meta name="title" content="Daffa Aufa | Creative Frontend Engineer & Designer" />
  <meta name="description" content="Editorial digital portfolio of Daffa Aufa, a creative frontend engineer & designer based in Indonesia. Fluid, non-grid editorial experiences." />
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&display=swap" rel="stylesheet">
  
  <!-- GSAP CDN -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

  <style>
    /* Reset & Variables */
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    :root {
      --bg: #090910;
      --surface: #0f0f1a;
      --accent: #c8ff00;
      --accent2: #ff4d6d;
      --text: #f5f0eb;
      --muted: #52525e;
      --border: rgba(255, 255, 255, 0.05);
      --font-display: 'Cormorant Garamond', serif;
      --font-body: 'DM Mono', monospace;
    }

    html {
      scroll-behavior: smooth;
      background-color: var(--bg);
      scrollbar-width: thin;
      scrollbar-color: var(--surface) var(--bg);
    }
    
    body {
      background-color: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      overflow-x: hidden;
      opacity: 0; /* Fades in during load sequence */
    }

    /* Custom Webkit Scrollbar */
    ::-webkit-scrollbar {
      width: 6px;
    }
    ::-webkit-scrollbar-track {
      background: var(--bg);
    }
    ::-webkit-scrollbar-thumb {
      background: var(--surface);
      border: 1px solid var(--border);
    }

    /* Custom cursor */
    @media (pointer: fine) {
      body {
        cursor: none;
      }
      a, button, select, input, textarea, .project-card {
        cursor: none !important;
      }
      .cursor-dot {
        position: fixed;
        top: 0; left: 0;
        width: 8px; height: 8px;
        background-color: var(--accent);
        border-radius: 50%;
        pointer-events: none;
        z-index: 99999;
        transform: translate(-50%, -50%);
        transition: width 0.3s, height 0.3s, background-color 0.3s, opacity 0.3s;
      }
      .cursor-ring {
        position: fixed;
        top: 0; left: 0;
        width: 40px; height: 40px;
        border: 1px solid rgba(200, 255, 0, 0.3);
        border-radius: 50%;
        pointer-events: none;
        z-index: 99998;
        transform: translate(-50%, -50%);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.4;
        transition: width 0.3s, height 0.3s, border-radius 0.3s, background-color 0.3s, opacity 0.3s, border-color 0.3s;
      }
      .cursor-text {
        font-family: var(--font-body);
        font-size: 0.55rem;
        color: #090910;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        opacity: 0;
        white-space: nowrap;
        pointer-events: none;
        transition: opacity 0.2s ease;
      }

      /* Hover States for Cursor */
      body.hovering-clickable .cursor-dot {
        width: 24px;
        height: 24px;
        background-color: rgba(200, 255, 0, 0.4);
        mix-blend-mode: difference;
      }
      body.hovering-clickable .cursor-ring {
        opacity: 0;
      }
      body.hovering-project .cursor-dot {
        opacity: 0;
      }
      body.hovering-project .cursor-ring {
        width: 70px;
        height: 70px;
        background-color: var(--accent);
        border-color: var(--accent);
        opacity: 1;
      }
      body.hovering-project .cursor-text {
        opacity: 1;
      }
    }

    /* Minimal fixed Nav */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 1000;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.5rem 4rem;
      background-color: transparent;
      transition: backdrop-filter 0.3s, background-color 0.3s, padding 0.3s;
    }
    nav.scrolled {
      background-color: rgba(9, 9, 16, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      padding: 1rem 4rem;
    }
    .nav-logo {
      font-family: var(--font-display);
      font-size: 1.8rem;
      font-style: italic;
      font-weight: 700;
      color: var(--text);
      text-decoration: none;
    }
    .nav-links-wrapper {
      position: relative;
      display: flex;
      align-items: center;
    }
    .nav-links {
      display: flex;
      gap: 3rem;
      list-style: none;
    }
    .nav-links a {
      font-family: var(--font-body);
      font-size: 0.65rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      text-decoration: none;
      transition: color 0.3s;
      padding: 0.5rem 0;
    }
    .nav-links a:hover {
      color: var(--text);
    }
    .nav-dot {
      position: absolute;
      width: 4px;
      height: 4px;
      background-color: var(--accent);
      border-radius: 50%;
      opacity: 0;
      pointer-events: none;
      transition: transform 0.35s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.3s ease;
      transform: translate(-50%, -50%);
    }
    .nav-border {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 1px;
      background-color: var(--text);
      opacity: 0.05;
      pointer-events: none;
    }

    /* Hero Section */
    .hero-section {
      min-height: 100vh;
      width: 100%;
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 0 4rem;
      overflow: hidden;
      background-color: var(--bg);
    }
    .hero-gradient-orb {
      position: absolute;
      top: -100px; right: -100px;
      width: 450px; height: 450px;
      background: radial-gradient(circle, rgba(200, 255, 0, 0.1) 0%, rgba(255, 77, 109, 0.02) 50%, transparent 70%);
      border-radius: 50%;
      filter: blur(60px);
      pointer-events: none;
      z-index: 1;
    }
    .hero-diagonal-line {
      position: absolute;
      top: 0;
      left: 0;
      width: 150vw;
      height: 1px;
      background: linear-gradient(90deg, rgba(255,255,255,0.01) 0%, rgba(255,255,255,0.07) 50%, rgba(255,255,255,0.01) 100%);
      transform: rotate(18deg);
      transform-origin: top left;
      pointer-events: none;
      z-index: 1;
    }
    .hero-vertical-label {
      position: absolute;
      left: 2rem;
      top: 50%;
      transform: translateY(-50%) rotate(-90deg);
      transform-origin: left center;
      font-family: var(--font-body);
      font-size: 0.65rem;
      color: var(--muted);
      letter-spacing: 0.25em;
      white-space: nowrap;
      z-index: 2;
    }
    .hero-content {
      width: 100%;
      z-index: 2;
      margin-top: 4rem;
    }
    .hero-title-mask {
      overflow: hidden;
      display: block;
    }
    .hero-title-main {
      font-family: var(--font-display);
      font-size: clamp(8rem, 18vw, 19rem);
      font-weight: 300;
      line-height: 0.8;
      color: var(--text);
      margin-left: -1vw;
      letter-spacing: -0.04em;
    }
    .hero-subheader-row {
      display: flex;
      justify-content: flex-end;
      width: 100%;
      margin-top: 3rem;
      padding-right: 4rem;
    }
    .hero-subtitle {
      font-family: var(--font-body);
      font-size: 0.78rem;
      color: var(--text);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      max-width: 340px;
      text-align: right;
      line-height: 1.8;
    }
    .hero-bottom-row {
      position: absolute;
      bottom: 3rem;
      left: 4rem;
      right: 4rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      z-index: 2;
    }
    .badge-pulse {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 0.55rem 1.1rem;
      background: rgba(200, 255, 0, 0.04);
      border: 1px solid rgba(200, 255, 0, 0.15);
      border-radius: 20px;
      font-family: var(--font-body);
      font-size: 0.65rem;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }
    .badge-dot {
      width: 6px;
      height: 6px;
      background-color: var(--accent);
      border-radius: 50%;
      position: relative;
    }
    .badge-dot::after {
      content: '';
      position: absolute;
      inset: -4px;
      border: 1px solid var(--accent);
      border-radius: 50%;
      animation: pulse 1.8s infinite;
    }
    @keyframes pulse {
      0% { transform: scale(0.8); opacity: 1; }
      100% { transform: scale(2.2); opacity: 0; }
    }
    .hero-scroll-indicator {
      font-family: var(--font-body);
      font-size: 0.65rem;
      color: var(--muted);
      letter-spacing: 0.15em;
    }

    /* Ticker / Marquees */
    .tickers-wrapper {
      background-color: var(--bg);
      width: 100%;
      overflow: hidden;
    }
    .ticker-row {
      display: flex;
      padding: 1.2rem 0;
      overflow: hidden;
      position: relative;
      width: 100%;
    }
    .ticker-row.border-top {
      border-top: 1px solid var(--border);
    }
    .ticker-row.border-middle {
      border-top: 1px solid var(--border);
    }
    .ticker-row.border-bottom {
      border-bottom: 1px solid var(--border);
    }
    .ticker-track {
      display: flex;
      width: max-content;
      gap: 4rem;
    }
    .ticker-item {
      font-family: var(--font-body);
      font-size: 0.65rem;
      color: var(--muted);
      letter-spacing: 0.22em;
      white-space: nowrap;
      text-transform: uppercase;
    }
    .track-forward {
      animation: marquee-forward 30s linear infinite;
    }
    .track-reverse {
      animation: marquee-reverse 30s linear infinite;
    }
    @keyframes marquee-forward {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    @keyframes marquee-reverse {
      0% { transform: translateX(-50%); }
      100% { transform: translateX(0); }
    }

    /* Editorial Header Layout */
    .section-header-editorial {
      display: flex;
      align-items: baseline;
      gap: 1.5rem;
      margin-bottom: 5rem;
    }
    .sec-num {
      font-family: var(--font-body);
      font-size: 0.8rem;
      color: var(--accent);
      letter-spacing: 0.1em;
    }
    .sec-title-editorial {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 5vw, 4.5rem);
      font-weight: 300;
      color: var(--text);
    }

    /* Selected Experiments (Work) */
    .experiments-section {
      padding: 10rem 4rem;
      background-color: var(--bg);
    }
    
    .project-card {
      position: relative;
      background-color: var(--surface);
      border: 1px solid var(--border);
      overflow: hidden;
      transition: border-color 0.4s ease;
    }
    .project-card:hover {
      border-color: rgba(200, 255, 0, 0.2);
    }
    .project-hover-bg {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, rgba(200,255,0,0.04) 0%, transparent 100%);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
      z-index: 1;
      pointer-events: none;
    }
    .project-card:hover .project-hover-bg {
      transform: scaleX(1);
    }

    /* Project 01: Featured */
    .project-featured {
      min-height: 80vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 5rem;
      position: relative;
    }
    .project-visual-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      opacity: 0.2;
      z-index: 0;
      pointer-events: none;
      transition: opacity 0.5s ease;
    }
    .project-featured:hover .project-visual-bg {
      opacity: 0.35;
    }
    .project-visual-bg svg {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .project-content {
      position: relative;
      z-index: 2;
      width: 100%;
    }
    .project-num {
      font-family: var(--font-body);
      font-size: 0.65rem;
      color: var(--muted);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      display: block;
      margin-bottom: 1.5rem;
    }
    .project-title-large {
      font-family: var(--font-display);
      font-size: clamp(4rem, 11vw, 8.5rem);
      font-weight: 300;
      line-height: 0.9;
      letter-spacing: -0.02em;
      margin-left: -2vw;
      color: var(--text);
    }
    .project-tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-top: 1.5rem;
      margin-bottom: 2rem;
    }
    .tag-pill {
      font-family: var(--font-body);
      font-size: 0.6rem;
      letter-spacing: 0.05em;
      color: var(--muted);
      border: 1px solid var(--border);
      padding: 0.35rem 0.8rem;
      border-radius: 12px;
      background-color: rgba(9, 9, 16, 0.4);
    }
    .proj-desc-wrapper {
      align-self: flex-end;
      max-width: 440px;
      margin-left: auto;
      margin-top: 1rem;
    }
    .project-desc {
      font-family: var(--font-body);
      font-size: 0.85rem;
      line-height: 1.7;
      color: var(--text);
      opacity: 0.8;
    }
    .project-link {
      font-family: var(--font-body);
      font-size: 0.72rem;
      color: var(--text);
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      margin-top: 2rem;
      transition: color 0.3s;
    }
    .project-link:hover {
      color: var(--accent);
    }
    .project-link .arrow-svg {
      transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
      display: inline-block;
    }
    .project-link:hover .arrow-svg {
      transform: translateX(8px) scale(1.2);
    }

    /* Projects Divider */
    .project-divider {
      position: relative;
      width: 100%;
      height: 1px;
      background-color: var(--border);
      margin: 8rem 0;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    .project-divider span {
      background-color: var(--bg);
      padding: 0 2rem;
      font-family: var(--font-body);
      font-size: 0.65rem;
      color: var(--muted);
      letter-spacing: 0.25em;
    }

    /* Asymmetric grid row for Projects 02 & 03 */
    .projects-asymmetric-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: start;
    }
    .project-left-weighted {
      grid-column: 1;
      width: 100%;
      max-width: 90%;
      padding: 3.5rem;
    }
    .project-right-weighted {
      grid-column: 2;
      width: 100%;
      max-width: 90%;
      margin-top: 8rem; /* Asymmetric vertical push */
      justify-self: end;
      padding: 3.5rem;
    }
    .project-title-medium {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3.8rem);
      font-weight: 300;
      line-height: 1.1;
      color: var(--text);
      margin-top: 1rem;
    }
    .project-left-weighted .project-desc, .project-right-weighted .project-desc {
      margin-top: 1.5rem;
      max-width: 360px;
    }

    /* Proficiencies Section */
    .proficiencies-section {
      padding: 10rem 4rem;
      background-color: var(--bg2);
      position: relative;
      overflow: hidden;
      border-top: 1px solid var(--border);
    }
    .faint-bg-number {
      position: absolute;
      font-family: var(--font-display);
      font-size: 32vw;
      font-weight: 900;
      color: rgba(255, 255, 255, 0.012);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
      z-index: 0;
      line-height: 1;
    }
    .skills-editorial-container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8rem;
      margin-top: 5rem;
      position: relative;
      z-index: 1;
    }
    .skills-col {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    .skills-col-title {
      font-family: var(--font-body);
      font-size: 0.72rem;
      color: var(--muted);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 2rem;
      border-bottom: 1px solid var(--border);
      padding-bottom: 1rem;
    }
    .skill-row {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      margin-bottom: 2rem;
      transition: transform 0.3s;
    }
    /* Alternating list indentations */
    .indent-1 { padding-left: 0; }
    .indent-2 { padding-left: 3.5rem; }
    .indent-3 { padding-left: 1.8rem; }
    
    .skill-meta {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }
    .skill-name {
      font-family: var(--font-display);
      font-size: 2.1rem;
      font-weight: 300;
      color: var(--text);
      transition: letter-spacing 0.4s cubic-bezier(0.25, 0.8, 0.25, 1), color 0.4s;
    }
    .skill-row:hover .skill-name {
      letter-spacing: 0.08em;
      color: var(--accent);
    }
    .skill-level {
      font-family: var(--font-body);
      font-size: 0.68rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .skill-bar {
      width: 100%;
      height: 1px;
      background-color: var(--border);
      position: relative;
      overflow: hidden;
    }
    .skill-bar-fill {
      position: absolute;
      top: 0; left: 0; bottom: 0;
      width: var(--skill-val);
      background-color: var(--accent);
      transform: scaleX(0);
      transform-origin: left;
    }

    /* About / Identity Section */
    .identity-section {
      padding: 10rem 4rem;
      background-color: var(--bg);
      border-top: 1px solid var(--border);
    }
    .about-quote {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 6vw, 5.2rem);
      font-style: italic;
      font-weight: 300;
      line-height: 1.15;
      text-align: left;
      width: 100%;
      margin-bottom: 6rem;
      color: var(--text);
      border-bottom: 1px solid var(--border);
      padding-bottom: 4rem;
    }
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 2rem 6rem;
      align-items: start;
    }
    .about-text-col-1 {
      grid-column: 1;
      margin-top: 6rem; /* Asymmetric vertical offset */
    }
    .about-para-1 {
      font-family: var(--font-body);
      font-size: 0.92rem;
      line-height: 1.8;
      color: var(--text);
      border-left: 2px solid var(--accent);
      padding-left: 1.8rem;
    }
    .about-text-col-2 {
      grid-column: 2;
      margin-top: 0;
    }
    .about-para-2 {
      font-family: var(--font-body);
      font-size: 0.92rem;
      line-height: 1.8;
      color: var(--muted);
    }
    .about-visual-wrapper {
      grid-column: span 2;
      margin-top: 7rem;
      display: flex;
      justify-content: center;
    }
    .about-avatar-masked {
      width: 100%;
      max-width: 960px;
      height: 460px;
      clip-path: polygon(10% 0%, 100% 0%, 90% 100%, 0% 100%);
      border: 1px solid var(--border);
      overflow: hidden;
      background-color: var(--surface);
    }
    .avatar-svg-art {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Contact Section */
    .contact-section {
      padding: 11rem 4rem;
      background-color: var(--bg);
      border-top: 1px solid var(--border);
      position: relative;
    }
    .contact-wrapper {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 4rem;
    }
    .contact-titles {
      display: flex;
      flex-direction: column;
    }
    .contact-lets {
      font-family: var(--font-display);
      font-size: clamp(5.5rem, 14vw, 11rem);
      font-weight: 300;
      line-height: 0.85;
      letter-spacing: -0.02em;
      color: var(--text);
    }
    .contact-build {
      font-family: var(--font-display);
      font-size: clamp(5.5rem, 14vw, 11rem);
      font-weight: 800;
      line-height: 0.85;
      letter-spacing: -0.02em;
      color: var(--text);
      margin-left: 6vw;
    }
    .contact-something-bold {
      font-family: var(--font-display);
      font-size: clamp(3.2rem, 7vw, 6.2rem);
      font-style: italic;
      font-weight: 200;
      color: var(--accent);
      text-align: right;
      margin-top: 1.5rem;
    }
    .contact-details {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-top: 6rem;
      flex-wrap: wrap;
      gap: 4rem;
    }
    .email-row {
      text-align: left;
    }
    .email-link {
      font-family: var(--font-body);
      font-size: 0.95rem;
      color: var(--text);
