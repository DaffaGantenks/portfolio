---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  
  <!-- Primary Meta Tags -->
  <title>Daffa Aufa | Creative Frontend Engineer & Designer</title>
  <meta name="title" content="Daffa Aufa | Creative Frontend Engineer & Designer" />
  <meta name="description" content="Portfolio of Daffa Aufa, a creative frontend engineer & designer based in Indonesia. Breaking grids with custom layout structures." />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
  
  <!-- GSAP CDN -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
</head>
<body>

  <!-- Custom Cursor -->
  <div class="cursor-dot" id="cursor-dot"></div>
  <div class="cursor-ring" id="cursor-ring">
    <span class="cursor-ring-text">VIEW →</span>
  </div>

  <!-- Floating Social Sidebar -->
  <div class="floating-social">
    <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="floating-social-btn" aria-label="GitHub">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
      </svg>
    </a>
    <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="floating-social-btn" aria-label="LinkedIn">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
    </a>
    <a href="https://dribbble.com" target="_blank" rel="noopener noreferrer" class="floating-social-btn" aria-label="Dribbble">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 24C5.385 24 0 18.615 0 12S5.385 0 12 0s12 5.385 12 12-5.385 12-12 12zm10.12-10.358c-.35-.11-3.17-.953-6.384-.438 1.34 3.684 1.887 6.684 1.992 7.308 2.3-1.555 3.936-4.02 4.395-6.87zm-6.115 7.808c-.153-.9-.75-4.032-2.19-7.77l-.066.02c-5.79 2.015-7.86 6.017-8.04 6.4 1.73 1.358 3.92 2.166 6.29 2.166 1.42 0 2.77-.29 4-.816zm-11.62-2.073c.232-.4 3.045-5.055 8.332-6.765.135-.045.27-.084.405-.12-.26-.585-.54-1.167-.832-1.74C7.17 12.35 2.Lower.73 2.05 11.85c.013.21.05.418.103.62.27 1.048.785 2 1.472 2.79zm2.16-8.67c.527.97 1.003 1.97 1.425 2.99 4.35-1.84 6.195-4.64 6.4-4.965-1.74-1.544-4.037-2.49-6.558-2.49-1.576 0-3.07.36-4.405 1.003.35.478.725.94 1.138 1.462zM14.45 3.8c-.22.33-2.22 3.25-6.395 4.888-.42-1.43-.93-2.83-1.524-4.17C8.02 3.52 9.46 3.155 10.985 3.155c1.23 0 2.41.232 3.465.645zm1.58.836c1.87.988 3.43 2.5 4.43 4.367-1.308.387-3.82.875-6.527.43-.198-.49-.41-.977-.635-1.457 1.05-1.158 2.032-2.42 2.733-3.34z"/>
      </svg>
    </a>
  </div>

  <!-- 1. Navigation -->
  <nav>
    <a href="#" class="nav-logo">Daffa</a>
    <ul class="nav-links">
      <li><a href="#work">Work</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#skills">Skills</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
    <hr class="nav-hr" />
  </nav>

  <!-- 2. Hero Section -->
  <section class="hero-section" id="hero">
    <!-- Layer 1: Blurred lime gradient orb -->
    <div class="hero-glow-orb"></div>
    
    <!-- Layer 2: Vertical label -->
    <div class="hero-vertical-label">
      PORTFOLIO 2026
    </div>
    
    <!-- Layer 3: Main title DAFFA AUFA -->
    <div class="hero-title-wrapper">
      <h1 class="hero-title">
        <span class="hero-title-mask"><span>DAFFA</span></span>
        <span class="hero-title-mask"><span>AUFA</span></span>
      </h1>
    </div>
    
    <!-- Layer 4: Sub-role -->
    <div class="hero-subrole-wrapper">
      <p class="hero-subrole">
        Creative Frontend Engineer<br />
        & Designer
      </p>
    </div>
    
    <!-- Layer 5: Diagonal line (removed) -->
    
    <!-- Layer 6: Open to work badge -->
    <div class="hero-badge-wrapper">
      <span class="hero-badge">
        <span class="hero-badge-dot"></span>
        Open to work — 2026
      </span>
    </div>
    
    <!-- Layer 7: Scroll Hint -->
    <a href="#work" class="hero-scroll-wrapper">
      <span class="hero-scroll-text">SCROLL</span>
      <span class="hero-scroll-arrow">↓</span>
    </a>
  </section>

  <!-- 3. Marquee Ticker -->
  <div class="marquee-container">
    <div class="marquee-row">
      <div class="marquee-track marquee-forward">
        <span class="marquee-item">Astro · Svelte · GSAP · Three.js · TypeScript · Figma · WebGL · PHP · Laravel · MySQL · PostgreSQL · Rust</span>
        <span class="marquee-item">Astro · Svelte · GSAP · Three.js · TypeScript · Figma · WebGL · PHP · Laravel · MySQL · PostgreSQL · Rust</span>
      </div>
    </div>
    <hr class="marquee-divider" />
    <div class="marquee-row">
      <div class="marquee-track marquee-reverse">
        <span class="marquee-item">Pixel Perfect · Performance Obsessed · UI Craftsman · Full Stack · Open Source · Available for Hire</span>
        <span class="marquee-item">Pixel Perfect · Performance Obsessed · UI Craftsman · Full Stack · Open Source · Available for Hire</span>
      </div>
    </div>
  </div>

  <!-- 4. Selected Experiments (Work) -->
  <section class="work-section" id="work">
    <div class="section-header-editorial">
      <span class="sec-num">01 //</span>
      <h2 class="sec-title-editorial">Selected Experiments</h2>
    </div>

    <div class="work-list">
      <!-- Project 01: Featured (Left-weighted title, right desc) -->
      <article class="project-card project-p1">
        <div class="project-card-header">
          <span class="project-num">01 / FEATURED</span>
          <div class="project-tags">
            <span class="project-tag">Web App</span>
            <span class="project-tag">Svelte 5</span>
            <span class="project-tag">Astro</span>
          </div>
        </div>
        
        <a href="#" class="project-title-link">
          <h3 class="project-title">Project Volantis — AI Business Dashboard</h3>
        </a>
        
        <div class="project-desc-wrapper">
          <p class="project-desc">A high-performance AI analytics platform offering real-time data visualization, predictive modeling, and automated report generation.</p>
          <a href="#" class="project-link-arrow">
            <span>Explore Case Study</span> <span class="arrow-char">→</span>
          </a>
        </div>
      </article>

      <div class="project-list-divider"><span>2024</span></div>

      <!-- Project 02: Right-weighted (Title right, tags left) -->
      <article class="project-card project-p2">
        <div class="project-card-header">
          <span class="project-num">02 / EXPERIMENT</span>
          <div class="project-tags">
            <span class="project-tag">3D Web</span>
            <span class="project-tag">WebGL</span>
            <span class="project-tag">Three.js</span>
          </div>
        </div>
        
        <a href="#" class="project-title-link">
          <h3 class="project-title">Aura 3D — Luxury Watch Configurator</h3>
        </a>
        
        <div class="project-desc-wrapper">
          <p class="project-desc">Real-time 3D product customization using WebGL, custom shaders, and interactive lighting environments.</p>
          <a href="#" class="project-link-arrow">
            <span>View Experiment</span> <span class="arrow-char">→</span>
          </a>
        </div>
      </article>

      <div class="project-list-divider"><span>2025</span></div>

      <!-- Project 03: Left-weighted (Title left, desc pushed right & offset lower) -->
      <article class="project-card project-p3">
        <div class="project-card-header">
          <span class="project-num">03 / STORYTELLING</span>
          <div class="project-tags">
            <span class="project-tag">UI/UX Design</span>
            <span class="project-tag">GSAP</span>
            <span class="project-tag">Motion</span>
          </div>
        </div>
        
        <a href="#" class="project-title-link">
          <h3 class="project-title">Elysian Brand — High Fashion Microsite</h3>
        </a>
        
        <div class="project-desc-wrapper">
          <p class="project-desc">A design system and storytelling digital experience for a luxury fashion house, featuring fluid typography and scroll-driven parallax.</p>
          <a href="#" class="project-link-arrow">
            <span>Explore Design</span> <span class="arrow-char">→</span>
          </a>
        </div>
      </article>

      <div class="project-list-divider"><span>2026</span></div>

      <!-- Project 04: Footnote/Bonus Project -->
      <article class="project-card project-p4">
        <div class="project-card-header">
          <span class="project-num">04 / OPEN SOURCE</span>
          <div class="project-tags">
            <span class="project-tag">TypeScript</span>
            <span class="project-tag">Canvas 2D</span>
          </div>
        </div>
        
        <a href="#" class="project-title-link">
          <h3 class="project-title">Chronos — Verlet Physics Simulator</h3>
        </a>
        
        <div class="project-desc-wrapper">
          <p class="project-desc">A lightweight canvas physics engine for rendering high-fidelity interactive particles and fluid simulations in web pages.</p>
          <a href="#" class="project-link-arrow">
            <span>View Code</span> <span class="arrow-char">→</span>
          </a>
        </div>
      </article>
    </div>
  </section>

  <!-- 5. Technical Skills (Proficiencies) -->
  <section class="skills-section" id="skills">
    <div class="skills-ghost-number">02</div>
    
    <div class="section-header-editorial">
      <span class="sec-num">02 //</span>
      <h2 class="sec-title-editorial">Proficiencies</h2>
    </div>

    <div class="skills-container">
      
      <!-- Frontend Craft Group -->
      <div class="skills-group">
        <h3 class="skills-group-title">Frontend Craft</h3>
        <div class="skills-list">
          
          <div class="skill-row">
            <div class="skill-meta">
              <span class="skill-name">Astro / Svelte</span>
              <span class="skill-level">— Expert</span>
            </div>
            <div class="skill-bar">
              <div class="skill-bar-fill" style="--percent: 92%"></div>
            </div>
          </div>
          
          <div class="skill-row">
            <div class="skill-meta">
              <span class="skill-name">GSAP / Motion</span>
              <span class="skill-level">— Advanced</span>
            </div>
            <div class="skill-bar">
              <div class="skill-bar-fill" style="--percent: 88%"></div>
            </div>
          </div>

          <div class="skill-row">
            <div class="skill-meta">
              <span class="skill-name">Three.js / WebGL</span>
              <span class="skill-level">— Intermediate</span>
            </div>
            <div class="skill-bar">
              <div class="skill-bar-fill" style="--percent: 72%"></div>
            </div>
          </div>

          <div class="skill-row">
            <div class="skill-meta">
              <span class="skill-name">TypeScript</span>
              <span class="skill-level">— Expert</span>
            </div>
            <div class="skill-bar">
              <div class="skill-bar-fill" style="--percent: 90%"></div>
            </div>
          </div>

          <div class="skill-row">
            <div class="skill-meta">
              <span class="skill-name">Figma</span>
              <span class="skill-level">— Expert</span>
            </div>
            <div class="skill-bar">
              <div class="skill-bar-fill" style="--percent: 92%"></div>
            </div>
          </div>

        </div>
      </div>

      <!-- Backend Architecture Group -->
      <div class="skills-group">
        <h3 class="skills-group-title">Backend Architecture</h3>
        <div class="skills-list">
          
          <div class="skill-row">
            <div class="skill-meta">
              <span class="skill-name">PHP</span>
              <span class="skill-level">— Advanced</span>
            </div>
            <div class="skill-bar">
              <div class="skill-bar-fill" style="--percent: 85%"></div>
            </div>
          </div>

          <div class="skill-row">
            <div class="skill-meta">
              <span class="skill-name">Laravel</span>
              <span class="skill-level">— Advanced</span>
            </div>
            <div class="skill-bar">
              <div class="skill-bar-fill" style="--percent: 88%"></div>
            </div>
          </div>

          <div class="skill-row">
            <div class="skill-meta">
              <span class="skill-name">MySQL</span>
              <span class="skill-level">— Advanced</span>
            </div>
            <div class="skill-bar">
              <div class="skill-bar-fill" style="--percent: 85%"></div>
            </div>
          </div>

          <div class="skill-row">
            <div class="skill-meta">
              <span class="skill-name">PostgreSQL</span>
              <span class="skill-level">— Intermediate</span>
            </div>
            <div class="skill-bar">
              <div class="skill-bar-fill" style="--percent: 80%"></div>
            </div>
          </div>

          <div class="skill-row">
            <div class="skill-meta">
              <span class="skill-name">Rust</span>
              <span class="skill-level">— Intermediate</span>
            </div>
            <div class="skill-bar">
              <div class="skill-bar-fill" style="--percent: 65%"></div>
            </div>
          </div>

          <div class="skill-row">
            <div class="skill-meta">
              <span class="skill-name">Node.js</span>
              <span class="skill-level">— Intermediate</span>
            </div>
            <div class="skill-bar">
              <div class="skill-bar-fill" style="--percent: 75%"></div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- 6. About / Identity Section -->
  <section class="about-section" id="about">
    <h2 class="about-quote">"I engineer interfaces that breathe."</h2>
    
    <div class="about-content">
      <p class="about-p-left">
        Daffa Aufa bridges the gap between raw engineering and high-end digital design. By treating web layouts as living canvases, every line of code becomes a deliberate choice in visual storytelling.
      </p>
      
      <p class="about-p-right">
        Working from Indonesia, Daffa collaborates with premium brands worldwide to deploy bespoke digital solutions. Combining lightweight static setups like Astro with powerful interaction frameworks like Svelte and GSAP, he builds websites that look like editorial fashion pieces while maintaining exceptional performance.
      </p>
      
      <div class="about-avatar-wrapper">
        <div class="about-avatar-masked">
          <!-- 📸 FOTO KAMU: taruh foto di public/images/profile.jpg -->
          <img
            src="/images/profile.jpg"
            alt="Daffa Aufa"
            class="about-avatar-photo"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <div class="about-avatar-initials" style="display:none;">DA</div>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Contact Section -->
  <section class="contact-section" id="contact">
    <div class="contact-container">
      <h2 class="contact-lets">LET'S</h2>
      <h2 class="contact-build">BUILD</h2>
      <div class="contact-something-bold">something bold.</div>
      
      <div class="contact-link-row">
        <a href="mailto:hello@daffaaufa.dev" class="contact-email-link">
          <span>hello@daffaaufa.dev</span> <span class="email-arrow">→</span>
        </a>
      </div>
      
      <div class="contact-social-cluster">
        <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="social-cluster-item social-item-github">GitHub</a>
        <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="social-cluster-item social-item-linkedin">LinkedIn</a>
        <a href="https://dribbble.com" target="_blank" rel="noopener noreferrer" class="social-cluster-item social-item-dribbble">Dribbble</a>
      </div>
    </div>
  </section>

  <!-- 8. Footer -->
  <footer>
    <div class="footer-left">
      © 2026 Daffa Aufa
    </div>
    <div class="footer-center">
      <span class="footer-asterisk">✦</span>
    </div>
    <div class="footer-right">
      Engineered with Astro + Svelte
    </div>
  </footer>

  <!-- Main JavaScript & GSAP Animations -->
  <script is:inline>
    // Dynamically load main.js after GSAP is ready
    (function() {
      var s = document.createElement('script');
      s.src = '/main.js';
      document.body.appendChild(s);
    })();
  </script>
</body>
</html>
