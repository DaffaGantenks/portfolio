---
import '../styles/global.css';
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Daffa Aufa — Creative Frontend Engineer & Designer crafting immersive digital experiences at the intersection of engineering precision and visual storytelling." />
  <title>Daffa Aufa — Creative Frontend Engineer & Designer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
</head>
<body data-theme="dark">

  <!-- Custom Cursor -->
  <div id="cursor-dot"></div>
  <div id="cursor-ring"></div>
  <div id="cursor-label"></div>

  <!-- Navigation -->
  <nav id="navbar">
    <a href="/" class="nav-logo"><em>DA</em></a>
    <ul class="nav-links">
      <li><a href="/" class="nav-link">Home</a></li>
      <li><a href="/projects" class="nav-link">Projects</a></li>
      <li><a href="/about" class="nav-link">About</a></li>
    </ul>
    <div class="nav-right">
      <a href="/cv-daffa-aufa.pdf" class="btn-resume" download>Resume ↓</a>
      <a href="#contact" class="btn-hire">Hire Me ↗</a>
      <button id="theme-toggle" aria-label="Toggle theme">◐</button>
    </div>
  </nav>

  <!-- ============================================================
       SECTION A: HERO
       ============================================================ -->
  <section id="hero">
    <div class="hero-left">
      <p class="hero-eyebrow">Creative Frontend Engineer &amp; Designer</p>
      <h1 class="hero-name">
        <span class="hero-first">Daffa</span>
        <span class="hero-last">Aufa</span>
      </h1>
      <p class="hero-desc">
        Crafting immersive digital experiences at the intersection of
        engineering precision and visual storytelling.
        Based in Malang, Indonesia — available worldwide.
      </p>
      <div class="hero-cta">
        <a href="/projects" class="btn-primary" data-cursor="WORK">View Work</a>
        <a href="/cv-daffa-aufa.pdf" class="btn-ghost" download data-cursor="CV">Download CV ↓</a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="stat-n">4+</span>
          <span class="stat-l">Years Coding</span>
        </div>
        <div class="hero-stat">
          <span class="stat-n">20+</span>
          <span class="stat-l">Projects</span>
        </div>
        <div class="hero-stat">
          <span class="stat-n">10+</span>
          <span class="stat-l">Clients</span>
        </div>
      </div>
    </div>

    <div class="hero-right">
      <div class="hero-avatar-wrap">
        <div class="hero-ring ring-outer"></div>
        <div class="hero-ring ring-inner"></div>
        <div class="hero-avatar-frame">
          <span class="hero-initials">DA</span>
        </div>
        <div class="hero-tag htag-1"><span class="tdot"></span>Frontend</div>
        <div class="hero-tag htag-2"><span class="tdot"></span>Full Stack</div>
        <div class="hero-tag htag-3"><span class="tdot"></span>Designer</div>
      </div>
    </div>

    <div class="hero-badge">
      <span class="badge-dot"></span>Available for work · 2026
    </div>
    <div class="hero-scroll">SCROLL ↓</div>
  </section>

  <!-- ============================================================
       SECTION B: SELECTED WORK — Bento Flip Cards
       ============================================================ -->
  <section id="work">
    <div class="section-header">
      <span class="section-num">01</span>
      <h2 class="section-title">Selected Work</h2>
      <a href="/projects" class="section-more" data-cursor="ALL">View All Archive →</a>
    </div>

    <div class="bento-grid">

      <!-- Card 1: Featured -->
      <div class="bento-card bento-featured">
        <div class="card-inner">
          <div class="card-front">
            <div class="card-bg bento-c1"></div>
            <div class="card-gradient"></div>
            <div class="card-content">
              <span class="card-type">WEB PROJECT</span>
              <h3 class="card-title">Project Volantis</h3>
              <p class="card-desc">AI-powered business intelligence dashboard with real-time data streams, predictive analytics, and immersive visualization.</p>
              <div class="card-tags">
                <span>Svelte</span><span>Astro</span><span>TypeScript</span><span>AI/ML</span>
              </div>
            </div>
          </div>
          <div class="card-back">
            <p class="back-title">Project Volantis</p>
            <p class="back-desc">A next-generation analytics platform bridging raw data and visual clarity — built for enterprise-scale insights.</p>
            <a href="/projects" class="back-link" data-cursor="VIEW">View in Archive →</a>
          </div>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="bento-card bento-medium">
        <div class="card-inner">
          <div class="card-front">
            <div class="card-bg bento-c2"></div>
            <div class="card-gradient"></div>
            <div class="card-content">
              <span class="card-type">EXPERIMENT</span>
              <h3 class="card-title">Aura 3D</h3>
              <div class="card-tags"><span>Three.js</span><span>WebGL</span></div>
            </div>
          </div>
          <div class="card-back">
            <p class="back-title">Aura 3D</p>
            <p class="back-desc">Interactive 3D luxury watch configurator with real-time WebGL material rendering and HDR reflections.</p>
            <a href="/projects" class="back-link" data-cursor="VIEW">View in Archive →</a>
          </div>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="bento-card bento-medium">
        <div class="card-inner">
          <div class="card-front">
            <div class="card-bg bento-c3"></div>
            <div class="card-gradient"></div>
            <div class="card-content">
              <span class="card-type">WEB PROJECT</span>
              <h3 class="card-title">Elysian</h3>
              <div class="card-tags"><span>Astro</span><span>GSAP</span></div>
            </div>
          </div>
          <div class="card-back">
            <p class="back-title">Elysian</p>
            <p class="back-desc">Cinematic high-fashion brand microsite with editorial scroll storytelling and GSAP timeline animations.</p>
            <a href="/projects" class="back-link" data-cursor="VIEW">View in Archive →</a>
          </div>
        </div>
      </div>

      <!-- Card 4 -->
      <div class="bento-card bento-wide">
        <div class="card-inner">
          <div class="card-front">
            <div class="card-bg bento-c4"></div>
            <div class="card-gradient"></div>
            <div class="card-content">
              <span class="card-type">TOOL</span>
              <h3 class="card-title">Chronos</h3>
              <div class="card-tags"><span>Rust</span><span>WASM</span><span>Canvas</span></div>
            </div>
          </div>
          <div class="card-back">
            <p class="back-title">Chronos</p>
            <p class="back-desc">Verlet physics simulator compiled from Rust to WebAssembly. Renders thousands of particles at 60fps.</p>
            <a href="/projects" class="back-link" data-cursor="VIEW">View in Archive →</a>
          </div>
        </div>
      </div>

      <!-- Card 5 -->
      <div class="bento-card bento-wide">
        <div class="card-inner">
          <div class="card-front">
            <div class="card-bg bento-c5"></div>
            <div class="card-gradient"></div>
            <div class="card-content">
              <span class="card-type">BACKEND</span>
              <h3 class="card-title">Nusantara API</h3>
              <div class="card-tags"><span>Laravel</span><span>PostgreSQL</span></div>
            </div>
          </div>
          <div class="card-back">
            <p class="back-title">Nusantara API</p>
            <p class="back-desc">Production-grade RESTful API for Indonesian geographic data. Built with Laravel and dual-database architecture.</p>
            <a href="/projects" class="back-link" data-cursor="VIEW">View in Archive →</a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ============================================================
       SECTION C: SKILLS — Physics Playground
       ============================================================ -->
  <section id="skills">
    <div class="section-header">
      <span class="section-num">02</span>
      <h2 class="section-title">Craft &amp; Stack</h2>
      <p class="section-note">Click to scatter · Drag to move</p>
    </div>
    <div class="skills-arena">
      <canvas id="physicsCanvas"></canvas>
    </div>
  </section>

  <!-- ============================================================
       SECTION D: CONTACT
       ============================================================ -->
  <section id="contact">
    <div class="contact-inner">
      <span class="section-num">03</span>
      <div class="contact-heading-wrap">
        <h2 class="contact-l1">HAVE AN</h2>
        <h2 class="contact-l2">IDEA?</h2>
        <p class="contact-sub">Let's build it together.</p>
      </div>

      <div class="contact-card">
        <p class="contact-card-label">Send me a message</p>
        <p class="contact-card-sub">Directly to my inbox. I reply quickly.</p>
        <a href="mailto:hello@daffaaufa.dev" class="contact-email-btn" data-cursor="MAIL">
          <span class="email-icon">✉</span>
          hello@daffaaufa.dev
          <span class="email-arrow">↗</span>
        </a>
        <button class="contact-copy" data-cursor="COPY">⧉ Copy address</button>
      </div>

      <div class="contact-socials">
        <a href="https://github.com/daffaaufa" target="_blank" class="social-btn" data-cursor="GITHUB">
          ⌥ GitHub
        </a>
        <a href="https://linkedin.com/in/daffaaufa" target="_blank" class="social-btn" data-cursor="LINK">
          ⊞ LinkedIn
        </a>
        <a href="https://dribbble.com/daffaaufa" target="_blank" class="social-btn" data-cursor="SHOTS">
          ◎ Dribbble
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <span>© 2026 Daffa Aufa</span>
    <span id="footerStar">✦</span>
    <span>Engineered with Astro + Svelte</span>
  </footer>

  <script src="/src/scripts/main.js"></script>
</body>
</html>
