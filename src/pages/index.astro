      letter-spacing: 0.1em;
      display: inline-flex;
      align-items: center;
      gap: 1.2rem;
      padding-bottom: 0.6rem;
      border-bottom: 1px solid var(--border);
      transition: border-color 0.3s, color 0.3s;
    }
    .email-link:hover {
      border-color: var(--accent);
      color: var(--accent);
    }
    .email-link .long-arrow {
      display: inline-block;
      transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    }
    .email-link:hover .long-arrow {
      transform: translateX(12px) scaleX(1.4);
    }
    .socials-cluster {
      position: relative;
      width: 240px;
      height: 140px;
    }
    .social-cluster-item {
      position: absolute;
      color: var(--muted);
      transition: color 0.3s, transform 0.3s, border-color 0.3s;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      background-color: var(--surface);
      border: 1px solid var(--border);
      border-radius: 50%;
    }
    .social-cluster-item:hover {
      color: var(--accent);
      border-color: rgba(200, 255, 0, 0.3);
      transform: scale(1.15);
    }
    .social-cluster-item svg {
      width: 18px;
      height: 18px;
    }
    /* Asymmetric cluster positioning */
    .social-cluster-item.item-1 { top: 0px; left: 10px; }
    .social-cluster-item.item-2 { top: 50px; left: 140px; }
    .social-cluster-item.item-3 { top: 80px; left: 40px; }

    /* Buttons shifting on hover */
    .btn-primary, .btn-outline {
      display: inline-block;
      position: relative;
      text-decoration: none;
    }
    .btn-primary span, .btn-outline span {
      display: inline-block;
      transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    }
    .btn-primary:hover span, .btn-outline:hover span {
      transform: translateY(-2px);
    }

