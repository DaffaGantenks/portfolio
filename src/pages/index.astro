---
import '../styles/global.css';
---
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Daffa Aufa — Creative Frontend Engineer & Designer based in Indonesia. Building immersive digital interfaces with Astro, Svelte, Three.js, and beyond." />
  <meta name="keywords" content="Daffa Aufa, Frontend Engineer, Web Designer, Astro, Svelte, Three.js, Indonesia, Portfolio" />
  <meta property="og:title" content="Daffa Aufa — Creative Frontend Engineer" />
  <meta property="og:description" content="I engineer interfaces that breathe. Creative Frontend Engineer & Designer based in Indonesia." />
  <meta property="og:type" content="website" />
  <title>Daffa Aufa — Creative Frontend Engineer & Designer</title>
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  <!-- GSAP -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
  <!-- Inline theme init: apply saved theme before first paint to avoid flash -->
  <script>
    (function() {
      const saved = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', saved);
    })();
  </script>
</head>
<body>

  <!-- Custom Cursor -->
  <div id="cursor-dot" aria-hidden="true"></div>
  <div id="cursor-ring" aria-hidden="true"></div>

  <!-- Navigation -->
  <nav id="main-nav" aria-label="Main navigation">
    <a href="#hero" class="nav-logo" aria-label="Daffa Aufa home"><em>DAFFA</em></a>
    <div class="nav-right">
      <a href="#work" class="nav-link">WORK</a>
      <a href="#about" class="nav-link">ABOUT</a>
      <a href="#skills" class="nav-link">SKILLS</a>
      <a href="#contact" class="nav-link">CONTACT</a>
      <button id="theme-toggle" aria-label="Toggle theme">
        <span class="toggle-icon">◐</span>
      </button>
    </div>
  </nav>

  <!-- Hero Section -->
  <section id="hero" aria-label="Hero">
    <!-- LEFT: Text Content -->
    <div class="hero-content">
      <p class="hero-eyebrow">Creative Frontend Engineer &amp; Designer</p>

      <h1 class="hero-name">
        <span class="hero-name-first">Daffa</span>
        <span class="hero-name-last">Aufa</span>
      </h1>

      <p class="hero-desc">
        Crafting immersive digital experiences at the intersection of
        engineering precision and visual storytelling. Based in Indonesia,
        available worldwide.
      </p>

      <div class="hero-cta">
        <a href="#work" class="btn-primary">View Work</a>
        <a href="#contact" class="btn-ghost">Let's Talk →</a>
      </div>
    </div>

    <!-- RIGHT: Avatar Visual -->
    <div class="hero-avatar-wrap" aria-hidden="true">
      <div class="hero-avatar-ring hero-ring-outer"></div>
      <div class="hero-avatar-ring hero-ring-middle"></div>
      <div class="hero-avatar-frame">
        <div class="hero-avatar-img">DA</div>
      </div>
      <div class="hero-avatar-tag tag-1">
        <span class="tag-dot"></span> Frontend
      </div>
      <div class="hero-avatar-tag tag-2">
        <span class="tag-dot"></span> Full Stack
      </div>
      <div class="hero-avatar-tag tag-3">
        <span class="tag-dot"></span> Designer
      </div>
    </div>

    <!-- Availability badge -->
    <div class="hero-badge" aria-label="Work availability status">
      <span class="badge-dot" aria-hidden="true"></span>
      Available for work · 2026
    </div>
  </section>



  <!-- Work Section -->
  <section id="work" aria-labelledby="work-heading">
    <div class="section-header">
      <span class="section-number">01</span>
      <h2 id="work-heading" class="section-title">Selected Work</h2>
    </div>

    <div class="bento-grid">

      <!-- Card 1: Featured Large -->
      <div class="bento-item" data-project="volantis">
        <div class="flip-card">
          <div class="flip-front" style="--card-glow: rgba(37,99,235,0.14);">
            <span class="project-number">001</span>
            <div class="project-tags-front">
              <span class="tag">Svelte</span>
              <span class="tag">Astro</span>
              <span class="tag">TypeScript</span>
            </div>
            <h3 class="project-title">Project<br/>Volantis</h3>
            <p class="project-subtitle">AI Business Dashboard</p>
          </div>
          <div class="flip-back">
            <span class="flip-back-number">001</span>
            <h3 class="flip-back-title">Project Volantis</h3>
            <p class="flip-back-desc">A real-time AI-powered business intelligence dashboard featuring live data streams, predictive analytics, and an immersive data visualization layer built for enterprise decision-making.</p>
            <div class="flip-tech">
              <span>Svelte</span>
              <span>Astro</span>
              <span>TypeScript</span>
              <span>WebSocket</span>
            </div>
            <a href="#" class="flip-link" aria-label="View Project Volantis">View Experiment →</a>
          </div>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="bento-item" data-project="aura">
        <div class="flip-card">
          <div class="flip-front" style="--card-glow: rgba(96,165,250,0.18);">
            <span class="project-number">002</span>
            <div class="project-tags-front">
              <span class="tag">Three.js</span>
              <span class="tag">WebGL</span>
            </div>
            <h3 class="project-title">Aura 3D</h3>
            <p class="project-subtitle">Luxury Watch Configurator</p>
          </div>
          <div class="flip-back">
            <span class="flip-back-number">002</span>
            <h3 class="flip-back-title">Aura 3D</h3>
            <p class="flip-back-desc">An interactive 3D luxury watch configurator with real-time material rendering, HDR reflections, and physics-based shading — entirely in the browser.</p>
            <div class="flip-tech">
              <span>Three.js</span>
              <span>WebGL</span>
              <span>GSAP</span>
            </div>
            <a href="#" class="flip-link" aria-label="View Aura 3D">View Experiment →</a>
          </div>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="bento-item" data-project="elysian">
        <div class="flip-card">
          <div class="flip-front" style="--card-glow: rgba(37,99,235,0.10);">
            <span class="project-number">003</span>
            <div class="project-tags-front">
              <span class="tag">Astro</span>
              <span class="tag">GSAP</span>
            </div>
            <h3 class="project-title">Elysian</h3>
            <p class="project-subtitle">High Fashion Microsite</p>
          </div>
          <div class="flip-back">
            <span class="flip-back-number">003</span>
            <h3 class="flip-back-title">Elysian</h3>
            <p class="flip-back-desc">A cinematic high-fashion brand microsite with editorial scroll storytelling, parallax layers, and choreographed GSAP timeline animations for a luxury aesthetic.</p>
            <div class="flip-tech">
              <span>Astro</span>
              <span>GSAP</span>
              <span>CSS</span>
            </div>
            <a href="#" class="flip-link" aria-label="View Elysian">View Experiment →</a>
          </div>
        </div>
      </div>

      <!-- Card 4 -->
      <div class="bento-item" data-project="chronos">
        <div class="flip-card">
          <div class="flip-front" style="--card-glow: rgba(96,165,250,0.12);">
            <span class="project-number">004</span>
            <div class="project-tags-front">
              <span class="tag">Rust</span>
              <span class="tag">WASM</span>
              <span class="tag">Canvas</span>
            </div>
            <h3 class="project-title">Chronos</h3>
            <p class="project-subtitle">Verlet Physics Simulator</p>
          </div>
          <div class="flip-back">
            <span class="flip-back-number">004</span>
            <h3 class="flip-back-title">Chronos</h3>
            <p class="flip-back-desc">A Verlet integration physics simulator compiled from Rust to WebAssembly, rendering thousands of real-time particle interactions on an HTML5 Canvas at 60fps.</p>
            <div class="flip-tech">
              <span>Rust</span>
              <span>WebAssembly</span>
              <span>Canvas</span>
            </div>
            <a href="#" class="flip-link" aria-label="View Chronos">View Experiment →</a>
          </div>
        </div>
      </div>

      <!-- Card 5 -->
      <div class="bento-item" data-project="nusantara">
        <div class="flip-card">
          <div class="flip-front" style="--card-glow: rgba(37,99,235,0.16);">
            <span class="project-number">005</span>
            <div class="project-tags-front">
              <span class="tag">Laravel</span>
              <span class="tag">PostgreSQL</span>
            </div>
            <h3 class="project-title">Nusantara<br/>API</h3>
            <p class="project-subtitle">RESTful Backend</p>
          </div>
          <div class="flip-back">
            <span class="flip-back-number">005</span>
            <h3 class="flip-back-title">Nusantara API</h3>
            <p class="flip-back-desc">A production-grade RESTful API platform serving geographic and cultural data for the Indonesian archipelago, built with Laravel's robust ecosystem and dual-database architecture.</p>
            <div class="flip-tech">
              <span>Laravel</span>
              <span>PHP</span>
              <span>PostgreSQL</span>
              <span>MySQL</span>
            </div>
            <a href="#" class="flip-link" aria-label="View Nusantara API">View Experiment →</a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" aria-labelledby="skills-heading">
    <div class="skills-header">
      <span class="section-num">02</span>
      <h2 id="skills-heading" class="section-title">Craft &amp; Stack</h2>
      <p class="skills-subtitle">Click &amp; drag the icons to explore</p>
    </div>
    <div class="skills-arena" id="skillsArena">
      <canvas id="physicsCanvas"></canvas>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" aria-labelledby="about-heading">
    <div class="section-header">
      <span class="section-number">03</span>
      <h2 id="about-heading" class="section-title">About</h2>
    </div>

    <blockquote class="about-quote">
      <em>"I engineer interfaces that breathe."</em>
    </blockquote>

    <div class="about-body">
      <div class="about-text-left">
        <p>Based in Indonesia, I build digital experiences at the intersection of engineering precision and artistic sensibility. Every pixel is intentional. Every transition, earned.</p>
      </div>

      <div class="about-avatar" aria-label="Daffa Aufa avatar initials">
        <span class="avatar-initials">DA</span>
      </div>

      <div class="about-text-right">
        <p>I've shipped products for startups across Southeast Asia and collaborated with design-forward teams worldwide. My stack is wide, my taste is specific, and my commit messages are poetry.</p>
        <p>When I'm not pushing code I'm hunting obscure type specimens, studying editorial layout, and obsessing over the 0.1s that separates smooth from perfect.</p>
      </div>
    </div>

    <div class="about-stats" aria-label="Career statistics">
      <div class="stat-item">
        <span class="stat-number">4+</span>
        <span class="stat-label">Years</span>
      </div>
      <div class="stat-divider" aria-hidden="true">·</div>
      <div class="stat-item">
        <span class="stat-number">20+</span>
        <span class="stat-label">Projects</span>
      </div>
      <div class="stat-divider" aria-hidden="true">·</div>
      <div class="stat-item">
        <span class="stat-number">10+</span>
        <span class="stat-label">Clients</span>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" aria-labelledby="contact-heading">
    <div class="contact-display">
      <div class="contact-lets">LET'S</div>
      <div class="contact-build">BUILD</div>
      <div class="contact-something">something bold.</div>
    </div>

    <div class="contact-body">
      <a href="mailto:hello@daffaaufa.dev" class="contact-email" id="contact-heading" aria-label="Send email to Daffa Aufa">
        hello@daffaaufa.dev <span class="email-arrow">→</span>
      </a>

      <div class="contact-socials">
        <a href="https://github.com" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <span class="social-icon">⌥</span>
          <span class="social-name">GitHub</span>
        </a>
        <a href="https://linkedin.com" class="social-link social-link--offset" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <span class="social-icon">⊞</span>
          <span class="social-name">LinkedIn</span>
        </a>
        <a href="https://dribbble.com" class="social-link social-link--high" target="_blank" rel="noopener noreferrer" aria-label="Dribbble">
          <span class="social-icon">◎</span>
          <span class="social-name">Dribbble</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer id="main-footer" aria-label="Site footer">
    <span class="footer-copy">© 2026 Daffa Aufa</span>
    <span class="footer-star" aria-hidden="true">✦</span>
    <span class="footer-built">Engineered with Astro + Svelte</span>
  </footer>

  <script>
    import '../scripts/main.js';
  </script>
</body>
</html>
