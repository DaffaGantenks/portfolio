    </div>
    <div class="footer-center">
      <span class="footer-asterisk">✦</span>
    </div>
    <div class="footer-right">
      <span>ENGINEERED WITH ASTRO + SVELTE</span>
    </div>
  </footer>

  <!-- Scripts -->
  <script is:inline>
    // Register GSAP plugins
    gsap.registerPlugin(ScrollTrigger);

    // Page Load Sequence
    window.addEventListener('DOMContentLoaded', () => {
      const tl = gsap.timeline();
      
      tl.to('body', { opacity: 1, duration: 0.3 })
        .fromTo('.hero-title-main', 
          { y: 150, filter: 'blur(15px)' },
          { y: 0, filter: 'blur(0px)', duration: 1.1, ease: 'power3.out' },
          '0.2'
        )
        .fromTo('nav', 
          { opacity: 0 }, 
          { opacity: 1, duration: 0.6 }, 
          '0.5'
        )
        .fromTo(['.hero-subtitle', '.badge-pulse', '.hero-vertical-label', '.hero-diagonal-line', '.hero-gradient-orb', '.hero-scroll-indicator'],
          { opacity: 0, y: 20 },
          { opacity: 1, y: 0, duration: 0.8, ease: 'power2.out', stagger: 0.12 },
          '0.6'
        );
    });

    // Custom Cursor tracking
    const dot = document.getElementById('cursor-dot');
    const ring = document.getElementById('cursor-ring');
    let mouseX = 0, mouseY = 0;
    let ringX = 0, ringY = 0;

    window.addEventListener('mousemove', e => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      if (dot) {
        dot.style.transform = `translate(${mouseX}px, -50%) translate3d(0,0,0)`;
        dot.style.left = '0';
        dot.style.top = '0';
      }
    });

    function animateRing() {
      ringX += (mouseX - ringX) * 0.15;
      ringY += (mouseY - ringY) * 0.15;
      if (ring) {
        ring.style.transform = `translate(${ringX}px, -50%) translate3d(0,0,0)`;
        ring.style.left = '0';
        ring.style.top = '0';
      }
      requestAnimationFrame(animateRing);
    }
    animateRing();

    // Hover listeners
    function setupCursorHovers() {
      document.querySelectorAll('a, button, .btn-primary, .btn-outline').forEach(el => {
        el.addEventListener('mouseenter', () => document.body.classList.add('hovering-clickable'));
        el.addEventListener('mouseleave', () => document.body.classList.remove('hovering-clickable'));
      });
      
      document.querySelectorAll('.project-card').forEach(el => {
        el.addEventListener('mouseenter', () => document.body.classList.add('hovering-project'));
        el.addEventListener('mouseleave', () => document.body.classList.remove('hovering-project'));
      });
    }
    setupCursorHovers();

    // Sliding Nav Link Indicator
    const links = document.querySelectorAll('.nav-links a');
    const navDot = document.getElementById('nav-dot');
    const navWrapper = document.querySelector('.nav-links-wrapper');

    if (links.length && navDot && navWrapper) {
      links.forEach(link => {
        link.addEventListener('mouseenter', () => {
          const rect = link.getBoundingClientRect();
          const wrapperRect = navWrapper.getBoundingClientRect();
          const left = rect.left - wrapperRect.left - 10;
          
          navDot.style.opacity = '1';
          navDot.style.transform = `translate(${left}px, -50%)`;
        });
      });
      
      navWrapper.addEventListener('mouseleave', () => {
        navDot.style.opacity = '0';
      });
    }

    // Scroll Blur Navigation Effect
    window.addEventListener('scroll', () => {
      const navEl = document.querySelector('nav');
      if (navEl) {
        if (window.scrollY > 40) {
          navEl.classList.add('scrolled');
        } else {
          navEl.classList.remove('scrolled');
        }
      }
    }, { passive: true });

    // GSAP Scroll Animations
    // 1. Editorial Headings slide-up + fade
    gsap.utils.toArray('.section-header-editorial').forEach(header => {
      gsap.fromTo(header,
        { y: 50, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 1,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: header,
            start: 'top 80%',
          }
        }
      );
    });

    // 2. Project Title slides
    gsap.fromTo('.project-featured .project-title-large',
      { x: -120, opacity: 0 },
      {
        x: 0,
        opacity: 1,
        duration: 1.2,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.project-featured',
          start: 'top 75%',
        }
      }
    );

    gsap.fromTo('.project-left-weighted .project-title-medium',
      { x: -80, opacity: 0 },
      {
        x: 0,
        opacity: 1,
        duration: 1.2,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.project-left-weighted',
          start: 'top 75%',
        }
      }
    );

    gsap.fromTo('.project-right-weighted .project-title-medium',
      { x: 80, opacity: 0 },
      {
        x: 0,
        opacity: 1,
        duration: 1.2,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.project-right-weighted',
          start: 'top 75%',
        }
      }
    );

    // 3. Technical Skill Lines ScaleX
    gsap.utils.toArray('.skill-bar-fill').forEach(bar => {
      gsap.to(bar, {
        scaleX: 1,
        duration: 1.5,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: bar,
          start: 'top 92%',
        }
      });
    });

    // 4. Contact Let's Build text animations
    gsap.fromTo('.contact-lets',
      { x: -60, opacity: 0 },
      {
        x: 0,
        opacity: 1,
        duration: 1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.contact-section',
          start: 'top 70%',
        }
      }
    );

    gsap.fromTo('.contact-build',
      { x: 60, opacity: 0 },
      {
        x: 0,
        opacity: 1,
        duration: 1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.contact-section',
          start: 'top 70%',
        }
      }
    );
  </script>
</body>
</html>
