      padding: 3rem 4rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-family: var(--font-body);
      font-size: 0.65rem;
      color: var(--muted);
      background-color: var(--bg);
