---
import Cursor from '../components/Cursor.svelte';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Daffa Aufa | Creative Frontend Engineer & Designer",
	description = "Portfolio of Daffa Aufa, a creative frontend engineer and designer crafting immersive digital experiences where aesthetics meet engineering precision."
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
	</head>
	<body>
		<!-- Smooth Custom Cursor -->
		<Cursor client:only="svelte" />
		<slot />
	</body>
</html>
